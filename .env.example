# ============================================================
# CrowdFlow - Environment Configuration
# Copy this file to `.env` and fill in your local credentials.
# Never commit your real .env to source control.
# ============================================================

# --- PostgreSQL connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crowdflow
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=crowdflow

# --- Flask ---
FLASK_APP=app
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production-use-a-long-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
